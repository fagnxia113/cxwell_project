# 应用配置
APP_NAME=汇升智合项目管理系统-后端
PORT=8080
NODE_ENV=development

# 数据库配置 (PostgreSQL)
# 格式: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/cxwell_v4"

# JWT 鉴权配置
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# 跨域配置
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 文件上传配置
UPLOAD_PATH=./uploads
FILE_URL_PREFIX=http://localhost:3000/api/files
