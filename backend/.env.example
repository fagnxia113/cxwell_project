# 应用配置
APP_NAME=汇升智合项目管理系统-后端
PORT=8080
NODE_ENV=production
# 前端访问地址 (用于生成钉钉消息中的跳转链接)
FRONTEND_URL=http://your-frontend-domain.com

# 数据库配置 (MySQL/PostgreSQL)
# 生产环境请替换为实际的数据库地址和凭据
DATABASE_URL="mysql://root:password@localhost:3306/cxwell_v4"

# JWT 鉴权配置
# 请在部署前生成一个强随机字符串作为密钥
JWT_SECRET=cxwell_enterprise_secret_2026
JWT_EXPIRES_IN=24h

# 跨域配置
# 生产环境请修改为实际的前端域名，多个域名用逗号分隔
CORS_ORIGINS=http://your-frontend-domain.com

# ============================================================
# 文件上传配置（核心迁移参数）
# ============================================================
# UPLOAD_PATH: 文件存储根目录（容器内路径）
#   默认 ./uploads，Docker 中映射到主机 ./data/uploads/
#   换云盘时只需改 Docker Compose 的 bind mount 路径即可
UPLOAD_PATH=./uploads

# FILE_URL_PREFIX: 文件访问 URL 前缀
#   本地存储时用相对路径 /api/files（通过 ServeStaticModule 提供静态文件服务）
#   迁移到 OSS/S3 时改为完整 URL，如 https://your-bucket.oss-cn-hangzhou.aliyuncs.com
FILE_URL_PREFIX=/api/files

# 钉钉配置 (需要在钉钉开发者后台获取)
DINGTALK_APP_KEY=your_app_key
DINGTALK_APP_SECRET=your_app_secret
DINGTALK_AGENT_ID=your_agent_id
