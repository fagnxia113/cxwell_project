# 应用配置
APP_NAME=汇升智合项目管理系统-后端
PORT=8080
NODE_ENV=production
# 前端访问地址 (用于生成钉钉消息中的跳转链接)
FRONTEND_URL=http://your-frontend-domain.com

# 数据库配置 (MySQL/PostgreSQL)
# 生产环境请替换为实际的数据库地址和凭据
DATABASE_URL="mysql://root:password@localhost:3306/cxwell_v4"

# JWT 鉴权配置
# 请在部署前生成一个强随机字符串作为密钥
JWT_SECRET=cxwell_enterprise_secret_2026
JWT_EXPIRES_IN=24h

# 跨域配置
# 生产环境请修改为实际的前端域名，多个域名用逗号分隔
CORS_ORIGINS=http://your-frontend-domain.com

# ============================================================
# 文件存储配置
# ============================================================
# STORAGE_TYPE: 存储类型
#   local - 本地磁盘存储（默认）
#   oss   - 阿里云 OSS 对象存储
STORAGE_TYPE=local

# UPLOAD_PATH: 文件存储根目录（容器内路径，仅本地存储时有效）
UPLOAD_PATH=./uploads

# FILE_URL_PREFIX: 文件访问 URL 前缀
#   本地存储: /api/files
#   OSS 存储: https://your-bucket.oss-cn-hangzhou.aliyuncs.com
FILE_URL_PREFIX=/api/files

# ============================================================
# 阿里云 OSS 配置（STORAGE_TYPE=oss 时需要配置）
# ============================================================
# OSS_REGION: OSS 地域，如 oss-cn-hangzhou、oss-cn-shanghai
OSS_REGION=oss-cn-hangzhou

# OSS_INTERNAL: 是否使用内网端点（仅当后端部署在阿里云 ECS 且与 OSS 同地域时设为 true）
#   非阿里云环境、Sealos、海外部署等必须设为 false，否则 OSS 初始化会失败
OSS_INTERNAL=false

# OSS_BUCKET: Bucket 名称
OSS_BUCKET=your-bucket-name

# OSS_ACCESS_KEY_ID: 阿里云 AccessKey ID
OSS_ACCESS_KEY_ID=your_access_key_id

# OSS_ACCESS_KEY_SECRET: 阿里云 AccessKey Secret
OSS_ACCESS_KEY_SECRET=your_access_key_secret

# ============================================================
# 钉钉配置 (需要在钉钉开发者后台获取)
# ============================================================
DINGTALK_APP_KEY=your_app_key
DINGTALK_APP_SECRET=your_app_secret
DINGTALK_AGENT_ID=your_agent_id
