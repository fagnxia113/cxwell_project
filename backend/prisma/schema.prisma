// This is your Prisma schema file.
// It integrates RuoYi's standard RBAC permission model with Warm-Flow's lightweight workflow engine model.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ----------------------------
// 1. 系统管理模块 (参照若依)
// ----------------------------

model SysDept {
  deptId     BigInt    @id @default(autoincrement()) @map("dept_id")
  parentId   BigInt    @default(0) @map("parent_id")
  ancestors  String    @default("") @db.VarChar(50)
  deptName   String    @default("") @map("dept_name") @db.VarChar(30)
  orderNum   Int       @default(0) @map("order_num")
  leader     String?   @db.VarChar(20)
  phone      String?   @db.VarChar(11)
  email      String?   @db.VarChar(50)
  status     String    @default("0") @db.Char(1)
  delFlag    String    @default("0") @map("del_flag") @db.Char(1)
  createBy   String    @default("") @map("create_by") @db.VarChar(64)
  createTime DateTime  @default(now()) @map("create_time")
  updateBy   String    @default("") @map("update_by") @db.VarChar(64)
  updateTime DateTime  @updatedAt @map("update_time")

  @@map("sys_dept")
}

model SysUser {
  userId      BigInt    @id @default(autoincrement()) @map("user_id")
  deptId      BigInt?   @map("dept_id")
  loginName   String    @unique @map("login_name") @db.VarChar(30)
  userName    String    @default("") @map("user_name") @db.VarChar(30)
  userType    String    @default("00") @map("user_type") @db.VarChar(2)
  email       String    @default("") @db.VarChar(50)
  phonenumber String    @default("") @db.VarChar(11)
  sex         String    @default("0") @db.Char(1)
  avatar      String    @default("") @db.VarChar(100)
  password    String    @default("") @db.VarChar(100)
  salt        String    @default("") @db.VarChar(64)
  status      String    @default("0") @db.Char(1)
  delFlag     String    @default("0") @map("del_flag") @db.Char(1)
  loginIp     String    @default("") @map("login_ip") @db.VarChar(128)
  loginDate   DateTime? @map("login_date")
  createBy    String    @default("") @map("create_by") @db.VarChar(64)
  createTime  DateTime  @default(now()) @map("create_time")
  updateBy    String    @default("") @map("update_by") @db.VarChar(64)
  updateTime  DateTime  @updatedAt @map("update_time")
  remark      String?   @db.VarChar(500)

  @@map("sys_user")
}

model SysRole {
  roleId     BigInt    @id @default(autoincrement()) @map("role_id")
  roleName   String    @map("role_name") @db.VarChar(30)
  roleKey    String    @map("role_key") @db.VarChar(100)
  roleSort   Int       @map("role_sort")
  dataScope  String    @default("1") @map("data_scope") @db.Char(1) // 1全部 2自定 3本部门 4本部门及以下
  status     String    @map("status") @db.Char(1)
  delFlag    String    @default("0") @map("del_flag") @db.Char(1)
  createBy   String    @default("") @map("create_by") @db.VarChar(64)
  createTime DateTime  @default(now()) @map("create_time")
  updateBy   String    @default("") @map("update_by") @db.VarChar(64)
  updateTime DateTime  @updatedAt @map("update_time")
  remark     String?   @db.VarChar(500)

  @@map("sys_role")
}

model SysMenu {
  menuId     BigInt    @id @default(autoincrement()) @map("menu_id")
  menuName   String    @map("menu_name") @db.VarChar(50)
  parentId   BigInt    @default(0) @map("parent_id")
  orderNum   Int       @default(0) @map("order_num")
  url        String    @default("#") @db.VarChar(200)
  target     String    @default("") @db.VarChar(20)
  menuType   String    @default("") @map("menu_type") @db.Char(1) // M目录 C菜单 F按钮
  visible    String    @default("0") @db.Char(1)
  perms      String?   @db.VarChar(100)
  icon       String    @default("#") @db.VarChar(100)
  createBy   String    @default("") @map("create_by") @db.VarChar(64)
  createTime DateTime  @default(now()) @map("create_time")
  updateBy   String    @default("") @map("update_by") @db.VarChar(64)
  updateTime DateTime  @updatedAt @map("update_time")
  remark     String?   @db.VarChar(500)

  @@map("sys_menu")
}

model SysRoleMenu {
  roleId BigInt @map("role_id")
  menuId BigInt @map("menu_id")

  @@id([roleId, menuId])
  @@map("sys_role_menu")
}

model SysUserRole {
  userId BigInt @map("user_id")
  roleId BigInt @map("role_id")

  @@id([userId, roleId])
  @@map("sys_user_role")
}

// ----------------------------
// 3. 业务基础模块 (人员与组织)
// ----------------------------

model SysEmployee {
  employeeId   BigInt    @id @default(autoincrement()) @map("employee_id")
  employeeNo   String?   @unique @map("employee_no") @db.VarChar(50)
  name         String    @db.VarChar(100)
  gender       String?   @db.Char(1) // 1男 2女 0未知
  phone        String    @db.VarChar(20)
  email        String?   @db.VarChar(100)
  deptId       BigInt?   @map("dept_id")
  position     String?   @db.VarChar(100)
  education    String?   @db.VarChar(100)
  university   String?   @db.VarChar(200)
  userId       BigInt?   @unique @map("user_id")
  status       String    @default("0") @db.Char(1) // 0在职 1离职
  hireDate     DateTime? @map("hire_date")
  leaveDate    DateTime? @map("leave_date")
  avatarColor  String?   @map("avatar_color") @db.VarChar(20)
  createTime   DateTime  @default(now()) @map("create_time")
  updateTime   DateTime  @updatedAt @map("update_time")

  projects     ProjectMember[]

  @@map("sys_employee")
}

model SysPost {
  postId       BigInt    @id @default(autoincrement()) @map("post_id")
  postCode     String    @unique @map("post_code") @db.VarChar(64)
  postName     String    @map("post_name") @db.VarChar(50)
  postLevel    Int       @default(1) @map("post_level")
  postSort     Int       @default(0) @map("post_sort")
  status       String    @default("0") @db.Char(1) // 0正常 1停用
  remark       String?   @db.VarChar(500)
  createBy     String?   @map("create_by") @db.VarChar(64)
  createTime   DateTime  @default(now()) @map("create_time")
  updateTime   DateTime  @updatedAt @map("update_time")

  @@map("sys_post")
}

// ----------------------------
// 4. 核心业务模块 (项目与任务)
// ----------------------------

model Customer {
  id           BigInt    @id @default(autoincrement())
  customerNo   String    @unique @map("customer_no") @db.VarChar(50)
  name         String    @db.VarChar(200)
  contact      String?   @db.VarChar(100)
  phone        String?   @db.VarChar(20)
  address      String?   @db.Text
  status       String    @default("0") @db.Char(1)
  createTime   DateTime  @default(now()) @map("create_time")
  updateTime   DateTime  @updatedAt @map("update_time")

  projects     Project[]

  @@map("biz_customer")
}

model Project {
  projectId    BigInt    @id @default(autoincrement()) @map("project_id")
  projectCode  String    @unique @map("project_code") @db.VarChar(50)
  projectName  String    @map("project_name") @db.VarChar(200)
  projectType  String?   @default("domestic") @map("project_type") @db.VarChar(50)
  customerId   BigInt?   @map("customer_id")
  managerId    BigInt?   @map("manager_id")
  status       String    @default("1") @db.Char(1) // 1预研 2立项 3进行中 4已完成 5已归档
  progress     Int       @default(0)
  startDate    DateTime  @map("start_date")
  endDate      DateTime? @map("end_date")
  budget       Decimal   @default(0.00) @db.Decimal(15, 2)
  description  String?   @db.Text
  
  customer     Customer? @relation(fields: [customerId], references: [id])
  members      ProjectMember[]
  tasks        BizTask[]
  milestones   ProjectMilestone[]
  risks        ProjectRisk[]
  expenses     ProjectExpense[]
  staffingPlans ProjectStaffingPlan[]
  reports      ProjectReport[]

  createBy     String?   @map("create_by") @db.VarChar(64)
  createTime   DateTime  @default(now()) @map("create_time")
  updateTime   DateTime  @updatedAt @map("update_time")
  delFlag      String    @default("0") @map("del_flag") @db.Char(1)

  @@map("biz_project")
}

model ProjectMember {
  id           BigInt    @id @default(autoincrement())
  projectId    BigInt    @map("project_id")
  employeeId   BigInt    @map("employee_id")
  roleName     String?   @map("role_name") @db.VarChar(50)
  canEdit      Boolean   @default(false) @map("can_edit")
  joinDate     DateTime  @default(now()) @map("join_date")

  project      Project   @relation(fields: [projectId], references: [projectId])
  employee     SysEmployee @relation(fields: [employeeId], references: [employeeId])

  @@unique([projectId, employeeId])
  @@map("biz_project_member")
}

model BizTask {
  taskId       BigInt    @id @default(autoincrement()) @map("task_id")
  projectId    BigInt    @map("project_id")
  taskName     String    @map("task_name") @db.VarChar(300)
  taskType     String?   @map("task_type") @db.VarChar(50)
  assigneeId   BigInt?   @map("assignee_id")
  status       String    @default("0") @db.Char(1) // 0待处理 1进行中 2已完成
  priority     String    @default("medium") @db.VarChar(20)
  progress     Int       @default(0)
  startDate    DateTime  @map("start_date")
  endDate      DateTime  @map("end_date")
  wbsCode      String?   @map("wbs_code") @db.VarChar(50)

  project      Project   @relation(fields: [projectId], references: [projectId])

  @@map("biz_task")
}

model ProjectMilestone {
  id           BigInt    @id @default(autoincrement())
  projectId    BigInt    @map("project_id")
  name         String    @db.VarChar(200)
  plannedDate  DateTime  @map("planned_date")
  actualDate   DateTime? @map("actual_date")
  status       String    @default("0") @db.Char(1)

  project      Project   @relation(fields: [projectId], references: [projectId])

  @@map("biz_project_milestone")
}

model ProjectRisk {
  id           BigInt    @id @default(autoincrement())
  projectId    BigInt    @map("project_id")
  title        String    @db.VarChar(200)
  description  String?   @db.Text
  level        String    @default("medium") @db.VarChar(20) // low, medium, high
  status       String    @default("open") @db.VarChar(20)   // open, closed
  ownerName    String?   @map("owner_name") @db.VarChar(100)
  createTime   DateTime  @default(now()) @map("create_time")
  updateTime   DateTime  @updatedAt @map("update_time")

  project      Project   @relation(fields: [projectId], references: [projectId])

  @@map("biz_project_risk")
}

model ProjectExpense {
  id           BigInt    @id @default(autoincrement())
  projectId    BigInt    @map("project_id")
  category     String    @db.VarChar(50) // equipment, labor, travel, material, other
  amount       Decimal   @db.Decimal(15, 2)
  date         DateTime
  notes        String?   @db.Text
  sourceType   String    @default("manual") @map("source_type") @db.VarChar(50) // manual, reimbursement
  sourceId     BigInt?   @map("source_id")
  createTime   DateTime  @default(now()) @map("create_time")
  updateTime   DateTime  @updatedAt @map("update_time")

  project      Project   @relation(fields: [projectId], references: [projectId])

  @@map("biz_project_expense")
}

model ProjectStaffingPlan {
  id           BigInt    @id @default(autoincrement())
  projectId    BigInt    @map("project_id")
  role         String    @db.VarChar(100)
  count        Int       @default(1)
  startDate    DateTime  @map("start_date")
  endDate      DateTime? @map("end_date")
  createTime   DateTime  @default(now()) @map("create_time")
  updateTime   DateTime  @updatedAt @map("update_time")

  project      Project   @relation(fields: [projectId], references: [projectId])

  @@map("biz_project_staffing_plan")
}

model ProjectReport {
  id           BigInt    @id @default(autoincrement())
  projectId    BigInt    @map("project_id")
  milestoneId  BigInt    @map("milestone_id")
  name         String    @db.VarChar(200)
  copies       Int       @default(1)
  status       String    @default("pending") @db.VarChar(20) // pending, submitted, verified
  remarks      String?   @db.Text
  
  project      Project   @relation(fields: [projectId], references: [projectId])
  attachments  ProjectReportAttachment[]

  createTime   DateTime  @default(now()) @map("create_time")
  updateTime   DateTime  @updatedAt @map("update_time")

  @@map("biz_project_report")
}

model ProjectReportAttachment {
  id           BigInt    @id @default(autoincrement())
  reportId     BigInt    @map("report_id")
  fileName     String    @map("file_name") @db.VarChar(255)
  fileUrl      String    @map("file_url") @db.VarChar(500)
  createTime   DateTime  @default(now()) @map("create_time")

  report       ProjectReport @relation(fields: [reportId], references: [id])

  @@map("biz_project_report_attachment")
}

// ----------------------------
// 5. 动态表单模块
// ----------------------------

model BizFormTemplate {
  id           BigInt    @id @default(autoincrement())
  templateKey  String    @unique @map("template_key") @db.VarChar(100)
  name         String    @db.VarChar(255)
  category     String?   @db.VarChar(50)
  fields       Json      @map("fields") // 表单字段定义
  layout       Json?     @map("layout") // 布局定义
  version      Int       @default(1)
  status       String    @default("0") @db.Char(1) // 0启用 1停用
  createBy     String?   @map("create_by") @db.VarChar(64)
  createTime   DateTime  @default(now()) @map("create_time")
  updateTime   DateTime  @updatedAt @map("update_time")

  @@map("biz_form_template")
}

model BizFormDraft {
  id           BigInt    @id @default(autoincrement())
  templateKey  String    @map("template_key") @db.VarChar(100)
  userId       BigInt    @map("user_id")
  formData     Json      @map("form_data")
  createTime   DateTime  @default(now()) @map("create_time")
  updateTime   DateTime  @updatedAt @map("update_time")

  @@map("biz_form_draft")
}

// Casbin 的 Node Adapter 常用表名
model CasbinRule {
  id    Int     @id @default(autoincrement())
  ptype String  @db.VarChar(255)
  v0    String? @db.VarChar(255)
  v1    String? @db.VarChar(255)
  v2    String? @db.VarChar(255)
  v3    String? @db.VarChar(255)
  v4    String? @db.VarChar(255)
  v5    String? @db.VarChar(255)

  @@map("casbin_rule")
}

// ----------------------------
// 2. 工作流核心模块 (参照Warm-Flow底座7表)
// ----------------------------

model FlowDefinition {
  id             BigInt    @id @map("id")
  flowCode       String    @map("flow_code") @db.VarChar(40)
  flowName       String    @map("flow_name") @db.VarChar(100)
  modelValue     String    @default("CLASSICS") @map("model_value") @db.VarChar(40)
  category       String?   @db.VarChar(100)
  version        String    @db.VarChar(20)
  isPublish      Int       @default(0) @map("is_publish") @db.SmallInt
  formCustom     String?   @default("N") @map("form_custom") @db.Char(1)
  formPath       String?   @map("form_path") @db.VarChar(100)
  activityStatus Int       @default(1) @map("activity_status") @db.SmallInt
  listenerType   String?   @map("listener_type") @db.VarChar(100)
  listenerPath   String?   @map("listener_path") @db.VarChar(400)
  ext            String?   @db.VarChar(500)
  createTime     DateTime? @map("create_time")
  createBy       String?   @default("") @map("create_by") @db.VarChar(64)
  updateTime     DateTime? @map("update_time")
  updateBy       String?   @default("") @map("update_by") @db.VarChar(64)
  delFlag        String?   @default("0") @map("del_flag") @db.Char(1)
  tenantId       String?   @map("tenant_id") @db.VarChar(40)

  @@map("flow_definition")
}

model FlowNode {
  id             BigInt    @id @map("id")
  nodeType       Int       @map("node_type") @db.SmallInt
  definitionId   BigInt    @map("definition_id")
  nodeCode       String    @map("node_code") @db.VarChar(100)
  nodeName       String?   @map("node_name") @db.VarChar(100)
  permissionFlag String?   @map("permission_flag") @db.VarChar(200)
  nodeRatio      Decimal?  @db.Decimal(6, 3) @map("node_ratio")
  coordinate     String?   @db.VarChar(100)
  anyNodeSkip    String?   @map("any_node_skip") @db.VarChar(100)
  listenerType   String?   @map("listener_type") @db.VarChar(100)
  listenerPath   String?   @map("listener_path") @db.VarChar(400)
  handlerType    String?   @map("handler_type") @db.VarChar(100)
  handlerPath    String?   @map("handler_path") @db.VarChar(400)
  formCustom     String?   @default("N") @map("form_custom") @db.Char(1)
  formPath       String?   @map("form_path") @db.VarChar(100)
  version        String    @db.VarChar(20)
  createTime     DateTime? @map("create_time")
  createBy       String?   @default("") @map("create_by") @db.VarChar(64)
  updateTime     DateTime? @map("update_time")
  updateBy       String?   @default("") @map("update_by") @db.VarChar(64)
  ext            String?   @db.Text
  delFlag        String?   @default("0") @map("del_flag") @db.Char(1)
  tenantId       String?   @map("tenant_id") @db.VarChar(40)

  @@map("flow_node")
}

model FlowSkip {
  id            BigInt    @id @map("id")
  definitionId  BigInt    @map("definition_id")
  nowNodeCode   String    @map("now_node_code") @db.VarChar(100)
  nowNodeType   Int?      @map("now_node_type") @db.SmallInt
  nextNodeCode  String    @map("next_node_code") @db.VarChar(100)
  nextNodeType  Int?      @map("next_node_type") @db.SmallInt
  skipName      String?   @map("skip_name") @db.VarChar(100)
  skipType      String?   @map("skip_type") @db.VarChar(40)
  skipCondition String?   @map("skip_condition") @db.VarChar(200)
  coordinate    String?   @db.VarChar(100)
  createTime    DateTime? @map("create_time")
  createBy      String?   @default("") @map("create_by") @db.VarChar(64)
  updateTime    DateTime? @map("update_time")
  updateBy      String?   @default("") @map("update_by") @db.VarChar(64)
  delFlag       String?   @default("0") @map("del_flag") @db.Char(1)
  tenantId      String?   @map("tenant_id") @db.VarChar(40)

  @@map("flow_skip")
}

model FlowInstance {
  id             BigInt    @id @map("id")
  definitionId   BigInt    @map("definition_id")
  businessId     String    @map("business_id") @db.VarChar(40)
  nodeType       Int       @map("node_type") @db.SmallInt
  nodeCode       String    @map("node_code") @db.VarChar(40)
  nodeName       String?   @map("node_name") @db.VarChar(100)
  variable       String?   @db.Text
  flowStatus     String    @map("flow_status") @db.VarChar(20)
  activityStatus Int       @default(1) @map("activity_status") @db.SmallInt
  defJson        String?   @map("def_json") @db.Text
  createTime     DateTime? @map("create_time")
  createBy       String?   @default("") @map("create_by") @db.VarChar(64)
  updateTime     DateTime? @map("update_time")
  updateBy       String?   @default("") @map("update_by") @db.VarChar(64)
  ext            String?   @db.VarChar(500)
  delFlag        String?   @default("0") @map("del_flag") @db.Char(1)
  tenantId       String?   @map("tenant_id") @db.VarChar(40)

  @@map("flow_instance")
}

model FlowTask {
  id            BigInt    @id @map("id")
  definitionId  BigInt    @map("definition_id")
  instanceId    BigInt    @map("instance_id")
  nodeCode      String    @map("node_code") @db.VarChar(100)
  nodeName      String?   @map("node_name") @db.VarChar(100)
  nodeType      Int       @map("node_type") @db.SmallInt
  flowStatus    String    @map("flow_status") @db.VarChar(20)
  formCustom    String?   @default("N") @map("form_custom") @db.Char(1)
  formPath      String?   @map("form_path") @db.VarChar(100)
  createTime    DateTime? @map("create_time")
  createBy      String?   @default("") @map("create_by") @db.VarChar(64)
  updateTime    DateTime? @map("update_time")
  updateBy      String?   @default("") @map("update_by") @db.VarChar(64)
  delFlag       String?   @default("0") @map("del_flag") @db.Char(1)
  tenantId      String?   @map("tenant_id") @db.VarChar(40)

  @@map("flow_task")
}

model FlowHisTask {
  id             BigInt    @id @map("id")
  definitionId   BigInt    @map("definition_id")
  instanceId     BigInt    @map("instance_id")
  taskId         BigInt    @map("task_id")
  nodeCode       String?   @map("node_code") @db.VarChar(100)
  nodeName       String?   @map("node_name") @db.VarChar(100)
  nodeType       Int?      @map("node_type") @db.SmallInt
  targetNodeCode String?   @map("target_node_code") @db.VarChar(200)
  targetNodeName String?   @map("target_node_name") @db.VarChar(200)
  approver       String?   @db.VarChar(40)
  cooperateType  Int       @default(0) @map("cooperate_type") @db.SmallInt
  collaborator   String?   @db.VarChar(500)
  skipType       String?   @map("skip_type") @db.VarChar(10)
  flowStatus     String    @map("flow_status") @db.VarChar(20)
  formCustom     String?   @default("N") @map("form_custom") @db.Char(1)
  formPath       String?   @map("form_path") @db.VarChar(100)
  ext            String?   @db.Text
  message        String?   @db.VarChar(500)
  variable       String?   @db.Text
  createTime     DateTime? @map("create_time")
  updateTime     DateTime? @map("update_time")
  delFlag        String?   @default("0") @map("del_flag") @db.Char(1)
  tenantId       String?   @map("tenant_id") @db.VarChar(40)

  @@map("flow_his_task")
}

model FlowUser {
  id          BigInt    @id @map("id")
  type        String    @db.Char(1)
  processedBy String?   @map("processed_by") @db.VarChar(80)
  associated  BigInt
  createTime  DateTime? @map("create_time")
  createBy    String?   @default("") @map("create_by") @db.VarChar(64)
  updateTime  DateTime? @map("update_time")
  updateBy    String?   @default("") @map("update_by") @db.VarChar(64)
  delFlag     String?   @default("0") @map("del_flag") @db.Char(1)
  tenantId    String?   @map("tenant_id") @db.VarChar(40)

  @@index([processedBy, type], name: "user_processed_type")
  @@index([associated], name: "user_associated_idx")
  @@map("flow_user")
}

model FlowForm {
  id          BigInt    @id @map("id")
  formName    String    @map("form_name") @db.VarChar(100)
  formCode    String    @unique @map("form_code") @db.VarChar(40)
  formContent String    @map("form_content") @db.Text
  createBy    String?   @default("") @map("create_by") @db.VarChar(64)
  createTime  DateTime? @map("create_time")
  updateBy    String?   @default("") @map("update_by") @db.VarChar(64)
  updateTime  DateTime? @map("update_time")
  delFlag     String?   @default("0") @map("del_flag") @db.Char(1)
  tenantId    String?   @map("tenant_id") @db.VarChar(40)

  @@map("flow_form")
}
