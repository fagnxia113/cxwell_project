// This is your Prisma schema file.
// It integrates RuoYi's standard RBAC permission model with Warm-Flow's lightweight workflow engine model.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ----------------------------
// 1. 系统管理模块 (参照若依)
// ----------------------------

model SysDept {
  deptId     BigInt    @id @default(autoincrement()) @map("dept_id")
  parentId   BigInt    @default(0) @map("parent_id")
  ancestors  String    @default("")
  deptName   String    @default("") @map("dept_name")
  orderNum   Int       @default(0) @map("order_num")
  leader     String?
  phone      String?
  email      String?
  status     String    @default("0")
  delFlag    String    @default("0") @map("del_flag")
  createBy   String    @default("") @map("create_by")
  createTime DateTime  @default(now()) @map("create_time")
  updateBy   String    @default("") @map("update_by")
  updateTime DateTime  @updatedAt @map("update_time")

  @@map("sys_dept")
}

model SysUser {
  userId      BigInt    @id @default(autoincrement()) @map("user_id")
  deptId      BigInt?   @map("dept_id")
  loginName   String    @unique @map("login_name")
  userName    String    @default("") @map("user_name")
  userType    String    @default("00") @map("user_type")
  email       String    @default("")
  phonenumber String    @default("")
  sex         String    @default("0")
  avatar      String    @default("")
  password    String    @default("")
  salt        String    @default("")
  status      String    @default("0")
  delFlag     String    @default("0") @map("del_flag")
  loginIp     String    @default("") @map("login_ip")
  loginDate   DateTime? @map("login_date")
  createBy    String    @default("") @map("create_by")
  createTime  DateTime  @default(now()) @map("create_time")
  updateBy    String    @default("") @map("update_by")
  updateTime  DateTime  @updatedAt @map("update_time")
  remark      String?

  @@map("sys_user")
}

model SysRole {
  roleId     BigInt    @id @default(autoincrement()) @map("role_id")
  roleName   String    @map("role_name")
  roleKey    String    @map("role_key")
  roleSort   Int       @map("role_sort")
  dataScope  String    @default("1") @map("data_scope") // 1全部 2自定 3本部门 4本部门及以下
  status     String    @map("status")
  delFlag    String    @default("0") @map("del_flag")
  createBy   String    @default("") @map("create_by")
  createTime DateTime  @default(now()) @map("create_time")
  updateBy   String    @default("") @map("update_by")
  updateTime DateTime  @updatedAt @map("update_time")
  remark     String?

  @@map("sys_role")
}

model SysMenu {
  menuId     BigInt    @id @default(autoincrement()) @map("menu_id")
  menuName   String    @map("menu_name")
  parentId   BigInt    @default(0) @map("parent_id")
  orderNum   Int       @default(0) @map("order_num")
  url        String    @default("#")
  target     String    @default("")
  menuType   String    @default("") @map("menu_type") // M目录 C菜单 F按钮
  visible    String    @default("0")
  perms      String?
  icon       String    @default("#")
  createBy   String    @default("") @map("create_by")
  createTime DateTime  @default(now()) @map("create_time")
  updateBy   String    @default("") @map("update_by")
  updateTime DateTime  @updatedAt @map("update_time")
  remark     String?

  @@map("sys_menu")
}

model SysRoleMenu {
  roleId BigInt @map("role_id")
  menuId BigInt @map("menu_id")

  @@id([roleId, menuId])
  @@map("sys_role_menu")
}

model SysUserRole {
  userId BigInt @map("user_id")
  roleId BigInt @map("role_id")

  @@id([userId, roleId])
  @@map("sys_user_role")
}

// ----------------------------
// 3. 业务基础模块 (人员与组织)
// ----------------------------

model SysEmployee {
  employeeId   BigInt    @id @default(autoincrement()) @map("employee_id")
  employeeNo   String?   @unique @map("employee_no")
  name         String
  gender       String? // 1男 2女 0未知
  phone        String
  email        String?
  deptId       BigInt?   @map("dept_id")
  position     String?
  education    String?
  university   String?
  userId       BigInt?   @unique @map("user_id")
  status       String    @default("0") // 0在职 1离职
  hireDate     DateTime? @map("hire_date")
  leaveDate    DateTime? @map("leave_date")
  avatarColor  String?   @map("avatar_color")
  createTime   DateTime  @default(now()) @map("create_time")
  updateTime   DateTime  @updatedAt @map("update_time")

  projects     ProjectMember[]

  @@map("sys_employee")
}

model SysPost {
  postId       BigInt    @id @default(autoincrement()) @map("post_id")
  postCode     String    @unique @map("post_code")
  postName     String    @map("post_name")
  postLevel    Int       @default(1) @map("post_level")
  postSort     Int       @default(0) @map("post_sort")
  status       String    @default("0") // 0正常 1停用
  remark       String?
  createBy     String?   @map("create_by")
  createTime   DateTime  @default(now()) @map("create_time")
  updateTime   DateTime  @updatedAt @map("update_time")

  @@map("sys_post")
}

// ----------------------------
// 4. 核心业务模块 (项目与任务)
// ----------------------------

model Customer {
  id           BigInt    @id @default(autoincrement())
  customerNo   String    @unique @map("customer_no")
  name         String
  contact      String?
  phone        String?
  address      String?
  status       String    @default("0")
  createTime   DateTime  @default(now()) @map("create_time")
  updateTime   DateTime  @updatedAt @map("update_time")

  projects     Project[]

  @@map("biz_customer")
}

model Project {
  projectId    BigInt    @id @default(autoincrement()) @map("project_id")
  projectCode  String    @unique @map("project_code")
  projectName  String    @map("project_name")
  projectType  String?   @default("domestic") @map("project_type")
  customerId   BigInt?   @map("customer_id")
  managerId    BigInt?   @map("manager_id")
  status       String    @default("1") // 1预研 2立项 3进行中 4已完成 5已归档
  progress     Int       @default(0)
  startDate    DateTime  @map("start_date")
  endDate      DateTime? @map("end_date")
  budget       Decimal   @default(0.00)
  description  String?
  
  customer     Customer? @relation(fields: [customerId], references: [id])
  members      ProjectMember[]
  tasks        BizTask[]
  milestones   ProjectMilestone[]
  risks        ProjectRisk[]
  expenses     ProjectExpense[]
  staffingPlans ProjectStaffingPlan[]
  reports      ProjectReport[]

  createBy     String?   @map("create_by")
  createTime   DateTime  @default(now()) @map("create_time")
  updateTime   DateTime  @updatedAt @map("update_time")
  delFlag      String    @default("0") @map("del_flag")

  @@map("biz_project")
}

model ProjectMember {
  id           BigInt    @id @default(autoincrement())
  projectId    BigInt    @map("project_id")
  employeeId   BigInt    @map("employee_id")
  roleName     String?   @map("role_name")
  canEdit      Boolean   @default(false) @map("can_edit")
  joinDate     DateTime  @default(now()) @map("join_date")

  project      Project   @relation(fields: [projectId], references: [projectId])
  employee     SysEmployee @relation(fields: [employeeId], references: [employeeId])

  @@unique([projectId, employeeId])
  @@map("biz_project_member")
}

model BizTask {
  taskId       BigInt    @id @default(autoincrement()) @map("task_id")
  projectId    BigInt    @map("project_id")
  taskName     String    @map("task_name")
  taskType     String?   @map("task_type")
  assigneeId   BigInt?   @map("assignee_id")
  status       String    @default("0") // 0待处理 1进行中 2已完成
  priority     String    @default("medium")
  progress     Int       @default(0)
  startDate    DateTime  @map("start_date")
  endDate      DateTime  @map("end_date")
  wbsCode      String?   @map("wbs_code")

  project      Project   @relation(fields: [projectId], references: [projectId])

  @@map("biz_task")
}

model ProjectMilestone {
  id           BigInt    @id @default(autoincrement())
  projectId    BigInt    @map("project_id")
  name         String
  plannedDate  DateTime  @map("planned_date")
  actualDate   DateTime? @map("actual_date")
  status       String    @default("0")

  project      Project   @relation(fields: [projectId], references: [projectId])

  @@map("biz_project_milestone")
}

model ProjectRisk {
  id           BigInt    @id @default(autoincrement())
  projectId    BigInt    @map("project_id")
  title        String
  description  String?
  level        String    @default("medium") // low, medium, high
  status       String    @default("open")   // open, closed
  ownerName    String?   @map("owner_name")
  createTime   DateTime  @default(now()) @map("create_time")
  updateTime   DateTime  @updatedAt @map("update_time")

  project      Project   @relation(fields: [projectId], references: [projectId])

  @@map("biz_project_risk")
}

model ProjectExpense {
  id           BigInt    @id @default(autoincrement())
  projectId    BigInt    @map("project_id")
  category     String // equipment, labor, travel, material, other
  amount       Decimal
  date         DateTime
  notes        String?
  sourceType   String    @default("manual") @map("source_type") // manual, reimbursement
  sourceId     BigInt?   @map("source_id")
  createTime   DateTime  @default(now()) @map("create_time")
  updateTime   DateTime  @updatedAt @map("update_time")

  project      Project   @relation(fields: [projectId], references: [projectId])

  @@map("biz_project_expense")
}

model ProjectStaffingPlan {
  id           BigInt    @id @default(autoincrement())
  projectId    BigInt    @map("project_id")
  role         String
  count        Int       @default(1)
  startDate    DateTime  @map("start_date")
  endDate      DateTime? @map("end_date")
  createTime   DateTime  @default(now()) @map("create_time")
  updateTime   DateTime  @updatedAt @map("update_time")

  project      Project   @relation(fields: [projectId], references: [projectId])

  @@map("biz_project_staffing_plan")
}

model ProjectReport {
  id           BigInt    @id @default(autoincrement())
  projectId    BigInt    @map("project_id")
  milestoneId  BigInt    @map("milestone_id")
  name         String
  copies       Int       @default(1)
  status       String    @default("pending") // pending, submitted, verified
  remarks      String?
  
  project      Project   @relation(fields: [projectId], references: [projectId])
  attachments  ProjectReportAttachment[]

  createTime   DateTime  @default(now()) @map("create_time")
  updateTime   DateTime  @updatedAt @map("update_time")

  @@map("biz_project_report")
}

model ProjectReportAttachment {
  id           BigInt    @id @default(autoincrement())
  reportId     BigInt    @map("report_id")
  fileName     String    @map("file_name")
  fileUrl      String    @map("file_url")
  createTime   DateTime  @default(now()) @map("create_time")

  report       ProjectReport @relation(fields: [reportId], references: [id])

  @@map("biz_project_report_attachment")
}

// ----------------------------
// 5. 动态表单模块
// ----------------------------

model BizFormTemplate {
  id           BigInt    @id @default(autoincrement())
  templateKey  String    @unique @map("template_key")
  name         String
  category     String?
  fields       String    @map("fields") // 表单字段定义
  layout       String?   @map("layout") // 布局定义
  version      Int       @default(1)
  status       String    @default("0") // 0启用 1停用
  createBy     String?   @map("create_by")
  createTime   DateTime  @default(now()) @map("create_time")
  updateTime   DateTime  @updatedAt @map("update_time")

  @@map("biz_form_template")
}

model BizFormDraft {
  id           BigInt    @id @default(autoincrement())
  templateKey  String    @map("template_key")
  userId       BigInt    @map("user_id")
  formData     String    @map("form_data")
  createTime   DateTime  @default(now()) @map("create_time")
  updateTime   DateTime  @updatedAt @map("update_time")

  @@map("biz_form_draft")
}

// Casbin 的 Node Adapter 常用表名
model CasbinRule {
  id    Int     @id @default(autoincrement())
  ptype String
  v0    String?
  v1    String?
  v2    String?
  v3    String?
  v4    String?
  v5    String?

  @@map("casbin_rule")
}

// ----------------------------
// 2. 工作流核心模块 (参照Warm-Flow底座7表)
// ----------------------------

model FlowDefinition {
  id             BigInt    @id @map("id")
  flowCode       String    @map("flow_code")
  flowName       String    @map("flow_name")
  modelValue     String    @default("CLASSICS") @map("model_value")
  category       String?
  version        String
  isPublish      Int       @default(0) @map("is_publish")
  formCustom     String?   @default("N") @map("form_custom")
  formPath       String?   @map("form_path")
  activityStatus Int       @default(1) @map("activity_status")
  listenerType   String?   @map("listener_type")
  listenerPath   String?   @map("listener_path")
  ext            String?
  createTime     DateTime? @map("create_time")
  createBy       String?   @default("") @map("create_by")
  updateTime     DateTime? @map("update_time")
  updateBy       String?   @default("") @map("update_by")
  delFlag        String?   @default("0") @map("del_flag")
  tenantId       String?   @map("tenant_id")

  @@map("flow_definition")
}

model FlowNode {
  id             BigInt    @id @map("id")
  nodeType       Int       @map("node_type")
  definitionId   BigInt    @map("definition_id")
  nodeCode       String    @map("node_code")
  nodeName       String?   @map("node_name")
  permissionFlag String?   @map("permission_flag")
  nodeRatio      Decimal?  @map("node_ratio")
  coordinate     String?
  anyNodeSkip    String?   @map("any_node_skip")
  listenerType   String?   @map("listener_type")
  listenerPath   String?   @map("listener_path")
  handlerType    String?   @map("handler_type")
  handlerPath    String?   @map("handler_path")
  formCustom     String?   @default("N") @map("form_custom")
  formPath       String?   @map("form_path")
  version        String
  createTime     DateTime? @map("create_time")
  createBy       String?   @default("") @map("create_by")
  updateTime     DateTime? @map("update_time")
  updateBy       String?   @default("") @map("update_by")
  ext            String?
  delFlag        String?   @default("0") @map("del_flag")
  tenantId       String?   @map("tenant_id")

  @@map("flow_node")
}

model FlowSkip {
  id            BigInt    @id @map("id")
  definitionId  BigInt    @map("definition_id")
  nowNodeCode   String    @map("now_node_code")
  nowNodeType   Int?      @map("now_node_type")
  nextNodeCode  String    @map("next_node_code")
  nextNodeType  Int?      @map("next_node_type")
  skipName      String?   @map("skip_name")
  skipType      String?   @map("skip_type")
  skipCondition String?   @map("skip_condition")
  coordinate    String?
  createTime    DateTime? @map("create_time")
  createBy      String?   @default("") @map("create_by")
  updateTime    DateTime? @map("update_time")
  updateBy      String?   @default("") @map("update_by")
  delFlag       String?   @default("0") @map("del_flag")
  tenantId      String?   @map("tenant_id")

  @@map("flow_skip")
}

model FlowInstance {
  id             BigInt    @id @map("id")
  definitionId   BigInt    @map("definition_id")
  businessId     String    @map("business_id")
  nodeType       Int       @map("node_type")
  nodeCode       String    @map("node_code")
  nodeName       String?   @map("node_name")
  variable       String?
  flowStatus     String    @map("flow_status")
  activityStatus Int       @default(1) @map("activity_status")
  defJson        String?   @map("def_json")
  createTime     DateTime? @map("create_time")
  createBy       String?   @default("") @map("create_by")
  updateTime     DateTime? @map("update_time")
  updateBy       String?   @default("") @map("update_by")
  ext            String?
  delFlag        String?   @default("0") @map("del_flag")
  tenantId       String?   @map("tenant_id")

  @@map("flow_instance")
}

model FlowTask {
  id            BigInt    @id @map("id")
  definitionId  BigInt    @map("definition_id")
  instanceId    BigInt    @map("instance_id")
  nodeCode      String    @map("node_code")
  nodeName      String?   @map("node_name")
  nodeType      Int       @map("node_type")
  flowStatus    String    @map("flow_status")
  formCustom    String?   @default("N") @map("form_custom")
  formPath      String?   @map("form_path")
  createTime    DateTime? @map("create_time")
  createBy      String?   @default("") @map("create_by")
  updateTime    DateTime? @map("update_time")
  updateBy      String?   @default("") @map("update_by")
  delFlag       String?   @default("0") @map("del_flag")
  tenantId      String?   @map("tenant_id")

  @@map("flow_task")
}

model FlowHisTask {
  id             BigInt    @id @map("id")
  definitionId   BigInt    @map("definition_id")
  instanceId     BigInt    @map("instance_id")
  taskId         BigInt    @map("task_id")
  nodeCode       String?   @map("node_code")
  nodeName       String?   @map("node_name")
  nodeType       Int?      @map("node_type")
  targetNodeCode String?   @map("target_node_code")
  targetNodeName String?   @map("target_node_name")
  approver       String?
  cooperateType  Int       @default(0) @map("cooperate_type")
  collaborator   String?
  skipType       String?   @map("skip_type")
  flowStatus     String    @map("flow_status")
  formCustom     String?   @default("N") @map("form_custom")
  formPath       String?   @map("form_path")
  ext            String?
  message        String?
  variable       String?
  createTime     DateTime? @map("create_time")
  updateTime     DateTime? @map("update_time")
  delFlag        String?   @default("0") @map("del_flag")
  tenantId       String?   @map("tenant_id")

  @@map("flow_his_task")
}

model FlowUser {
  id          BigInt    @id @map("id")
  type        String
  processedBy String?   @map("processed_by")
  associated  BigInt
  createTime  DateTime? @map("create_time")
  createBy    String?   @default("") @map("create_by")
  updateTime  DateTime? @map("update_time")
  updateBy    String?   @default("") @map("update_by")
  delFlag     String?   @default("0") @map("del_flag")
  tenantId    String?   @map("tenant_id")

  @@index([processedBy, type], name: "user_processed_type")
  @@index([associated], name: "user_associated_idx")
  @@map("flow_user")
}

model FlowForm {
  id          BigInt    @id @map("id")
  formName    String    @map("form_name")
  formCode    String    @unique @map("form_code")
  formContent String    @map("form_content")
  createBy    String?   @default("") @map("create_by")
  createTime  DateTime? @map("create_time")
  updateBy    String?   @default("") @map("update_by")
  updateTime  DateTime? @map("update_time")
  delFlag     String?   @default("0") @map("del_flag")
  tenantId    String?   @map("tenant_id")

  @@map("flow_form")
}
