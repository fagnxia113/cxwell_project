generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model approval_orders {
  id           String                     @id @db.VarChar(36)
  order_type   approval_orders_order_type
  title        String                     @db.VarChar(200)
  applicant_id String                     @db.VarChar(36)
  target_id    String?                    @db.VarChar(36)
  from_id      String?                    @db.VarChar(36)
  to_id        String?                    @db.VarChar(36)
  form_data    Json?
  status       approval_orders_status?    @default(pending)
  wecom_sp_no  String?                    @db.VarChar(100)
  created_at   DateTime?                  @default(now()) @db.Timestamp(0)
  updated_at   DateTime?                  @default(now()) @db.Timestamp(0)
}

model attendance_records {
  id                      String                               @id @db.VarChar(36)
  employee_id             String                               @db.VarChar(36)
  project_id              String?                              @db.VarChar(36)
  date                    DateTime                             @db.Date
  check_in_time           DateTime?                            @db.DateTime(0)
  check_in_location_name  String?                              @db.VarChar(255)
  check_in_latitude       Decimal?                             @db.Decimal(10, 8)
  check_in_longitude      Decimal?                             @db.Decimal(11, 8)
  check_in_photo          String?                              @db.Text
  check_in_status         attendance_records_check_in_status?  @default(normal)
  check_out_time          DateTime?                            @db.DateTime(0)
  check_out_location_name String?                              @db.VarChar(255)
  check_out_latitude      Decimal?                             @db.Decimal(10, 8)
  check_out_longitude     Decimal?                             @db.Decimal(11, 8)
  check_out_photo         String?                              @db.Text
  check_out_status        attendance_records_check_out_status? @default(normal)
  work_status             attendance_records_work_status?      @default(off)
  is_verified             Boolean?                             @default(false)
  verified_by             String?                              @db.VarChar(36)
  verified_at             DateTime?                            @db.DateTime(0)
  notes                   String?                              @db.Text
  created_at              DateTime?                            @default(now()) @db.Timestamp(0)
  updated_at              DateTime?                            @default(now()) @db.Timestamp(0)

  @@unique([employee_id, date], map: "uk_emp_date")
  @@index([date], map: "idx_date")
  @@index([project_id], map: "idx_project")
  @@index([work_status], map: "idx_status")
}

model attendance_weekly_approvals {
  id              String                              @id @db.VarChar(36)
  project_id      String                              @db.VarChar(36)
  week_start_date DateTime                            @db.Date
  week_end_date   DateTime                            @db.Date
  approver_id     String                              @db.VarChar(36)
  status          attendance_weekly_approvals_status? @default(pending)
  summary_json    Json?
  created_at      DateTime?                           @default(now()) @db.Timestamp(0)
  updated_at      DateTime?                           @default(now()) @db.Timestamp(0)

  @@unique([project_id, week_start_date], map: "uk_proj_week")
}

model customers {
  id                      String                    @id @db.VarChar(36)
  customer_no             String                    @unique(map: "customer_no") @db.VarChar(50)
  name                    String                    @db.VarChar(200)
  contact                 String                    @db.VarChar(100)
  phone                   String                    @db.VarChar(20)
  address                 String?                   @db.Text
  notes                   String?                   @db.Text
  type                    customers_type?           @default(enterprise)
  created_at              DateTime?                 @default(now()) @db.Timestamp(0)
  updated_at              DateTime?                 @default(now()) @db.Timestamp(0)
  project_proposal_orders project_proposal_orders[]
}

model daily_reports {
  id              String                @id @db.VarChar(36)
  employee_id     String                @db.VarChar(36)
  report_date     DateTime              @db.Date
  summary         String                @db.Text
  plan            String?               @db.Text
  problems        String?               @db.Text
  status          daily_reports_status? @default(pending)
  reviewer_id     String?               @db.VarChar(36)
  reviewed_at     DateTime?             @db.Timestamp(0)
  created_at      DateTime?             @default(now()) @db.Timestamp(0)
  checkload_items Json?
  attendance_id   String?               @db.VarChar(36)

  @@index([report_date], map: "idx_daily_reports_report_date")
  @@index([status], map: "idx_daily_reports_status")
  @@index([employee_id], map: "idx_employee")
}

model project_reports {
  id            String    @id @db.VarChar(36)
  project_id    String    @db.VarChar(36)
  milestone_id  String?   @db.VarChar(36)
  name          String    @db.VarChar(255)
  copies        Int       @default(1)
  status        String?   @db.VarChar(50)
  remarks       String?   @db.Text
  submit_copies Int       @default(0)
  submit_date   DateTime? @db.Timestamp(0)
  file_url      String?   @db.VarChar(500)
  file_name     String?   @db.VarChar(255)
  created_at    DateTime? @default(now()) @db.Timestamp(0)
  updated_at    DateTime? @db.Timestamp(0)

  @@index([project_id], map: "idx_project_reports_project_id")
}

model project_report_attachments {
  id         String    @id @db.VarChar(36)
  report_id  String    @db.VarChar(36)
  file_url   String    @db.VarChar(500)
  file_name  String    @db.VarChar(255)
  file_size  Int?
  mime_type  String?   @db.VarChar(100)
  created_at DateTime? @default(now()) @db.Timestamp(0)

  @@index([report_id], map: "idx_project_report_attachments_report_id")
}

model departments {
  id                 String              @id @db.VarChar(36)
  code               String              @unique(map: "code") @db.VarChar(50)
  name               String              @db.VarChar(100)
  parent_id          String?             @db.VarChar(36)
  manager_id         String?             @db.VarChar(36)
  manager_name       String?             @db.VarChar(100)
  level              Int?                @default(1)
  path               String?             @db.VarChar(500)
  sort_order         Int?                @default(0)
  status             departments_status? @default(active)
  description        String?             @db.Text
  third_party_id     String?             @db.VarChar(100)
  third_party_source String?             @db.VarChar(50)
  created_at         DateTime?           @default(now()) @db.Timestamp(0)
  updated_at         DateTime?           @default(now()) @db.Timestamp(0)
  employees          employees?          @relation(fields: [manager_id], references: [id], onUpdate: NoAction, map: "fk_dept_manager")
  departments        departments?        @relation("departmentsTodepartments", fields: [parent_id], references: [id], onUpdate: NoAction, map: "fk_dept_parent")
  other_departments  departments[]       @relation("departmentsTodepartments")
  positions          positions[]

  @@index([parent_id], map: "idx_departments_parent_id")
  @@index([status], map: "idx_departments_status")
  @@index([level], map: "idx_level")
  @@index([manager_id], map: "idx_manager")
  @@index([third_party_id, third_party_source], map: "idx_third_party")
}

model domain_events {
  id             String    @id @db.VarChar(36)
  event_type     String    @db.VarChar(100)
  aggregate_id   String    @db.VarChar(36)
  aggregate_type String    @db.VarChar(50)
  payload        Json
  metadata       Json?
  status         String    @default("pending") @db.VarChar(20)
  error          String?   @db.Text
  retries        Int       @default(0)
  created_at     DateTime  @default(now()) @db.Timestamp(0)
  processed_at   DateTime? @db.Timestamp(0)

  @@index([aggregate_id], map: "idx_aggregate")
  @@index([status], map: "idx_status")
}

model employee_offboard_orders {
  id                                                         String                                 @id @db.VarChar(36)
  order_no                                                   String                                 @unique(map: "order_no") @db.VarChar(50)
  applicant_id                                               String                                 @db.VarChar(36)
  applicant                                                  String                                 @db.VarChar(100)
  apply_date                                                 DateTime                               @db.Date
  employee_id                                                String                                 @db.VarChar(36)
  employee_name                                              String?                                @db.VarChar(100)
  department                                                 String?                                @db.VarChar(100)
  position                                                   String?                                @db.VarChar(100)
  hire_date                                                  DateTime?                              @db.Date
  offboard_type                                              employee_offboard_orders_offboard_type
  offboard_reason                                            String                                 @db.Text
  expected_offboard_date                                     DateTime                               @db.Date
  handover_person_id                                         String?                                @db.VarChar(36)
  handover_person                                            String?                                @db.VarChar(100)
  actual_offboard_date                                       DateTime?                              @db.Date
  status                                                     employee_offboard_orders_status?       @default(draft)
  approval_id                                                String?                                @db.VarChar(36)
  approved_at                                                DateTime?                              @db.Timestamp(0)
  approved_by                                                String?                                @db.VarChar(36)
  created_at                                                 DateTime?                              @default(now()) @db.Timestamp(0)
  updated_at                                                 DateTime?                              @default(now()) @db.Timestamp(0)
  employees_employee_offboard_orders_applicant_idToemployees employees                              @relation("employee_offboard_orders_applicant_idToemployees", fields: [applicant_id], references: [id], onUpdate: NoAction, map: "fk_offboard_applicant")
  employees_employee_offboard_orders_employee_idToemployees  employees                              @relation("employee_offboard_orders_employee_idToemployees", fields: [employee_id], references: [id], onUpdate: NoAction, map: "fk_offboard_employee")

  @@index([applicant_id], map: "idx_applicant")
  @@index([employee_id], map: "idx_employee")
  @@index([status], map: "idx_status")
}

model employee_onboard_orders {
  id                  String                                @id @db.VarChar(36)
  order_no            String                                @unique(map: "order_no") @db.VarChar(50)
  applicant_id        String                                @db.VarChar(36)
  applicant           String                                @db.VarChar(100)
  apply_date          DateTime                              @db.Date
  name                String                                @db.VarChar(100)
  gender              employee_onboard_orders_gender?
  phone               String                                @db.VarChar(20)
  email               String?                               @db.VarChar(100)
  id_card             String                                @db.VarChar(18)
  department          String                                @db.VarChar(100)
  position            String                                @db.VarChar(100)
  hire_date           DateTime                              @db.Date
  employee_type       employee_onboard_orders_employee_type
  employee_no         String?                               @db.VarChar(50)
  created_employee_id String?                               @db.VarChar(36)
  status              employee_onboard_orders_status?       @default(draft)
  approval_id         String?                               @db.VarChar(36)
  approved_at         DateTime?                             @db.Timestamp(0)
  approved_by         String?                               @db.VarChar(36)
  created_at          DateTime?                             @default(now()) @db.Timestamp(0)
  updated_at          DateTime?                             @default(now()) @db.Timestamp(0)
  employees           employees                             @relation(fields: [applicant_id], references: [id], onUpdate: NoAction, map: "fk_onboard_applicant")

  @@index([applicant_id], map: "idx_applicant")
  @@index([department], map: "idx_department")
  @@index([order_no], map: "idx_employee_onboard_orders_order_no")
  @@index([status], map: "idx_employee_onboard_orders_status")
}

model employee_transfer_orders {
  id                                                         String                                 @id @db.VarChar(36)
  order_no                                                   String                                 @unique(map: "order_no") @db.VarChar(50)
  applicant_id                                               String                                 @db.VarChar(36)
  applicant                                                  String                                 @db.VarChar(100)
  apply_date                                                 DateTime                               @db.Date
  employee_id                                                String                                 @db.VarChar(36)
  employee_name                                              String?                                @db.VarChar(100)
  from_department                                            String?                                @db.VarChar(100)
  from_position                                              String?                                @db.VarChar(100)
  transfer_type                                              employee_transfer_orders_transfer_type
  to_department                                              String                                 @db.VarChar(100)
  to_position                                                String                                 @db.VarChar(100)
  transfer_reason                                            String                                 @db.Text
  effective_date                                             DateTime                               @db.Date
  status                                                     employee_transfer_orders_status?       @default(draft)
  approval_id                                                String?                                @db.VarChar(36)
  approved_at                                                DateTime?                              @db.Timestamp(0)
  approved_by                                                String?                                @db.VarChar(36)
  created_at                                                 DateTime?                              @default(now()) @db.Timestamp(0)
  updated_at                                                 DateTime?                              @default(now()) @db.Timestamp(0)
  employees_employee_transfer_orders_applicant_idToemployees employees                              @relation("employee_transfer_orders_applicant_idToemployees", fields: [applicant_id], references: [id], onUpdate: NoAction, map: "fk_transfer_order_applicant")
  employees_employee_transfer_orders_employee_idToemployees  employees                              @relation("employee_transfer_orders_employee_idToemployees", fields: [employee_id], references: [id], onUpdate: NoAction, map: "fk_transfer_order_employee")

  @@index([applicant_id], map: "idx_applicant")
  @@index([employee_id], map: "idx_employee")
  @@index([order_no], map: "idx_employee_transfer_orders_order_no")
  @@index([status], map: "idx_employee_transfer_orders_status")
}

model employees {
  id                                                                                          String                              @id @db.VarChar(36)
  employee_no                                                                                 String?                             @unique(map: "employee_no") @db.VarChar(50)
  name                                                                                        String                              @db.VarChar(100)
  gender                                                                                      employees_gender?
  phone                                                                                       String                              @db.VarChar(20)
  email                                                                                       String?                             @db.VarChar(100)
  department_id                                                                               String?                             @db.VarChar(36)
  position                                                                                    String                              @db.VarChar(100)
  user_id                                                                                     String?                             @db.VarChar(36)
  status                                                                                      employees_status?                   @default(active)
  current_status                                                                              employees_current_status?           @default(on_duty)
  hire_date                                                                                   DateTime                            @db.Date
  leave_date                                                                                  DateTime?                           @db.Date
  role                                                                                        employees_role?                     @default(user)
  daily_cost                                                                                  Decimal?                            @db.Decimal(10, 2)
  skills                                                                                      Json?
  avatar_color                                                                                String?                             @db.VarChar(20)
  data_permission                                                                             employees_data_permission?          @default(self)
  employee_type                                                                               employees_employee_type?            @default(full_time)
  created_at                                                                                  DateTime?                           @default(now()) @db.Timestamp(0)
  updated_at                                                                                  DateTime?                           @default(now()) @db.Timestamp(0)
  deleted_at                                                                                  DateTime?                           @db.Timestamp(0)
  departments                                                                                 departments[]
  employee_offboard_orders_employee_offboard_orders_applicant_idToemployees                   employee_offboard_orders[]          @relation("employee_offboard_orders_applicant_idToemployees")
  employee_offboard_orders_employee_offboard_orders_employee_idToemployees                    employee_offboard_orders[]          @relation("employee_offboard_orders_employee_idToemployees")
  employee_onboard_orders                                                                     employee_onboard_orders[]
  employee_transfer_orders_employee_transfer_orders_applicant_idToemployees                   employee_transfer_orders[]          @relation("employee_transfer_orders_applicant_idToemployees")
  employee_transfer_orders_employee_transfer_orders_employee_idToemployees                    employee_transfer_orders[]          @relation("employee_transfer_orders_employee_idToemployees")
  equipment_accessory_instances                                                               equipment_accessory_instances[]
  leave_requests                                                                              leave_requests[]
  personnel_rotation_plans                                                                    personnel_rotation_plans[]
  project_completion_orders                                                                   project_completion_orders[]
  project_personnel_transfer_orders_project_personnel_transfer_orders_applicant_idToemployees project_personnel_transfer_orders[] @relation("project_personnel_transfer_orders_applicant_idToemployees")
  project_personnel_transfer_orders_project_personnel_transfer_orders_employee_idToemployees  project_personnel_transfer_orders[] @relation("project_personnel_transfer_orders_employee_idToemployees")
  project_proposal_orders_project_proposal_orders_applicant_idToemployees                     project_proposal_orders[]           @relation("project_proposal_orders_applicant_idToemployees")
  project_proposal_orders_project_proposal_orders_manager_idToemployees                       project_proposal_orders[]           @relation("project_proposal_orders_manager_idToemployees")
  task_completion_orders                                                                      task_completion_orders[]

  @@index([department_id], map: "idx_dept")
  @@index([department_id, status], map: "idx_employees_department_status")
  @@index([user_id], map: "idx_employees_user_id")
  @@index([status], map: "idx_status")
}

model personnel_rotation_plans {
  id            String    @id @db.VarChar(36)
  employee_id   String    @db.VarChar(36)
  year_month    String    @db.VarChar(7)
  schedule_data Json
  status        String?   @default("submitted") @db.VarChar(20)
  submitted_at  DateTime? @default(now()) @db.Timestamp(0)
  updated_at    DateTime? @default(now()) @db.Timestamp(0)
  employees     employees @relation(fields: [employee_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_rotation_employee")

  @@unique([employee_id, year_month], map: "uk_emp_month")
}

model equipment_accessories {
  id                 String                                    @id @db.VarChar(36)
  quantity           Int?                                      @default(1)
  created_at         DateTime?                                 @default(now()) @db.Timestamp(0)
  updated_at         DateTime?                                 @default(now()) @db.Timestamp(0)
  accessory_category equipment_accessories_accessory_category?
  accessory_id       String                                    @db.VarChar(36)
  accessory_model    String?                                   @db.VarChar(100)
  accessory_name     String?                                   @db.VarChar(200)
  host_equipment_id  String                                    @db.VarChar(36)
  is_required        Boolean?                                  @default(false)
  notes              String?                                   @db.Text

  @@unique([host_equipment_id, accessory_id], map: "uk_host_accessory")
  @@index([accessory_id], map: "idx_accessory")
  @@index([host_equipment_id], map: "idx_host_equipment")
}

model equipment_accessory_instances {
  id                  String                                         @id @db.VarChar(36)
  accessory_name      String                                         @db.VarChar(200)
  model_no            String?                                        @db.VarChar(100)
  brand               String?                                        @db.VarChar(100)
  category            equipment_accessory_instances_category
  unit                String?                                        @default("个") @db.VarChar(20)
  quantity            Int?                                           @default(1)
  serial_number       String?                                        @db.VarChar(100)
  manage_code         String?                                        @unique(map: "manage_code") @db.VarChar(50)
  health_status       equipment_accessory_instances_health_status?   @default(normal)
  usage_status        equipment_accessory_instances_usage_status?    @default(idle)
  location_status     equipment_accessory_instances_location_status? @default(warehouse)
  location_id         String?                                        @db.VarChar(36)
  host_equipment_id   String?                                        @db.VarChar(36)
  keeper_id           String?                                        @db.VarChar(36)
  purchase_date       DateTime?                                      @db.Date
  purchase_price      Decimal?                                       @db.Decimal(12, 2)
  supplier            String?                                        @db.VarChar(200)
  notes               String?                                        @db.Text
  created_at          DateTime?                                      @default(now()) @db.Timestamp(0)
  updated_at          DateTime?                                      @default(now()) @db.Timestamp(0)
  tracking_type       equipment_accessory_instances_tracking_type    @default(SERIALIZED)
  attachments         Json?
  version             Int                                            @default(1)
  source_type         equipment_accessory_instances_source_type?     @default(inbound_separate)
  status              equipment_accessory_instances_status?          @default(normal)
  bound_at            DateTime?                                      @db.DateTime(0)
  deleted_at          DateTime?                                      @db.Timestamp(0)
  equipment_instances equipment_instances?                           @relation(fields: [host_equipment_id], references: [id])
  employees           employees?                                     @relation(fields: [keeper_id], references: [id])

  @@index([keeper_id], map: "equipment_accessory_instances_keeper_id_fkey")
  @@index([location_id], map: "equipment_accessory_instances_location_id_fkey")
  @@index([accessory_name, model_no], map: "idx_accessory_name")
  @@index([tracking_type], map: "idx_accessory_tracking_type")
  @@index([host_equipment_id], map: "idx_host_equipment")
  @@index([location_status, location_id], map: "idx_location")
}

model equipment_accessory_lost_records {
  id                String                                   @id @db.VarChar(36)
  accessory_id      String                                   @db.VarChar(36)
  equipment_id      String?                                  @db.VarChar(36)
  transfer_order_id String?                                  @db.VarChar(36)
  lost_at           DateTime                                 @db.DateTime(0)
  lost_by           String                                   @db.VarChar(36)
  lost_by_name      String?                                  @db.VarChar(100)
  lost_reason       String?                                  @db.Text
  found_at          DateTime?                                @db.DateTime(0)
  found_by          String?                                  @db.VarChar(36)
  found_by_name     String?                                  @db.VarChar(100)
  status            equipment_accessory_lost_records_status? @default(lost)
  notes             String?                                  @db.Text
  created_at        DateTime?                                @default(now()) @db.Timestamp(0)
  updated_at        DateTime?                                @default(now()) @db.Timestamp(0)

  @@index([accessory_id], map: "idx_accessory")
  @@index([equipment_id], map: "idx_equipment")
  @@index([lost_at], map: "idx_lost_at")
  @@index([status], map: "idx_status")
  @@index([transfer_order_id], map: "idx_transfer_order")
}

model equipment_images {
  id             String                          @id @db.VarChar(36)
  equipment_id   String?                         @db.VarChar(36)
  equipment_name String?                         @db.VarChar(200)
  model_no       String?                         @db.VarChar(100)
  category       equipment_images_category?
  image_type     equipment_images_image_type
  image_url      String                          @db.VarChar(500)
  image_name     String?                         @db.VarChar(200)
  image_size     Int?
  image_format   String?                         @db.VarChar(20)
  business_type  equipment_images_business_type?
  business_id    String?                         @db.VarChar(36)
  uploader_id    String?                         @db.VarChar(36)
  uploader_name  String?                         @db.VarChar(100)
  notes          String?                         @db.Text
  created_at     DateTime?                       @default(now()) @db.Timestamp(0)
  updated_at     DateTime?                       @default(now()) @db.Timestamp(0)

  @@index([business_type, business_id], map: "idx_business")
  @@index([equipment_id], map: "idx_equipment_id")
  @@index([image_type], map: "idx_image_type")
  @@index([uploader_id], map: "idx_uploader")
}

model equipment_inbound_items {
  id                       String                          @id @db.VarChar(36)
  order_id                 String                          @db.VarChar(36)
  equipment_name           String?                         @db.VarChar(200)
  manufacturer             String?                         @db.VarChar(200)
  serial_number            String?                         @db.VarChar(100)
  quantity                 Int?
  category                 String?                         @db.VarChar(50)
  technical_params         String?                         @db.Text
  created_at               DateTime?                       @default(now()) @db.Timestamp(0)
  accessory_desc           String?                         @db.Text
  attachment               String?                         @db.VarChar(500)
  brand                    String?                         @db.VarChar(100)
  certificate_expiry_date  DateTime?                       @db.Date
  certificate_issuer       String?                         @db.VarChar(200)
  certificate_no           String?                         @db.VarChar(100)
  item_notes               String?                         @db.Text
  model_name               String?                         @db.VarChar(100)
  model_no                 String?                         @db.VarChar(100)
  purchase_price           Decimal?                        @db.Decimal(10, 2)
  serial_numbers           String?                         @db.Text
  status                   equipment_inbound_items_status? @default(pending)
  supplier                 String?                         @db.VarChar(200)
  technical_doc            String?                         @db.Text
  unit                     String?                         @db.VarChar(20)
  updated_at               DateTime?                       @default(now()) @db.Timestamp(0)
  equipment_inbound_orders equipment_inbound_orders        @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "equipment_inbound_items_ibfk_1")

  @@index([order_id], map: "idx_order_id")
  @@index([status], map: "idx_status")
}

model equipment_inbound_orders {
  id                              String                                           @id @db.VarChar(36)
  order_no                        String                                           @unique(map: "order_no") @db.VarChar(50)
  warehouse_id                    String                                           @db.VarChar(36)
