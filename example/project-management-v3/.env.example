# 服务器配置
SERVER_PORT=8080

# 前端配置
FRONTEND_PORT=3000

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password
DB_DATABASE=project_management

# JWT 密钥
JWT_SECRET=your_jwt_secret_key_here

# CORS 允许的前端地址（逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 文件上传目录配置（可选，默认为项目根目录下的 uploads 文件夹）
UPLOAD_DIR=
EQUIPMENT_IMAGE_DIR=

# 日志目录配置（可选，默认为项目根目录下的 logs 文件夹）
LOG_DIR=

# 后端 API 基础地址（用于内部服务调用，如企业微信同步）
# 本地开发留空，默认使用 http://localhost:SERVER_PORT
API_BASE_URL=

# 公网部署时，前端需要指定后端 API 地址（Vite 环境变量必须以 VITE_ 开头）
# 本地开发留空，公网部署时设置为后端地址，如：https://api.example.com
VITE_API_BASE_URL=

# Vite 开发服务器允许的主机（逗号分隔，用于内网穿透）
# 默认: .trycloudflare.com,.ngrok-free.app,localhost
VITE_ALLOWED_HOSTS=.trycloudflare.com,.ngrok-free.app,localhost

# 环境
NODE_ENV=development
