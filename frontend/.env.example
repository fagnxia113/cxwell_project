# 生产环境 API 基础路径 (部署时修改为实际后端地址)
VITE_API_BASE_URL=http://your-backend-api.com

# 网页标题
VITE_APP_TITLE=汇升智合项目管理系统

# 前端服务端口
VITE_PORT=3000

# 开发环境代理目标 (仅本地开发使用)
VITE_PROXY_TARGET=http://localhost:8080

# 允许访问的主机名 (用于 Sealos 或生产环境，多个用逗号隔开)
# 例如: "jlxayywgrwee.sealosbja.site,your-domain.com"
VITE_ALLOWED_HOSTS="jlxayywgrwee.sealosbja.site"
